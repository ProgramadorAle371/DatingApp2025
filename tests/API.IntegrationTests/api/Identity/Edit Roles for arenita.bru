meta {
  name: Edit Roles for arenita
  type: http
  seq: 12
}

put {
  url: {{baseUrl}}/api/admin/roles/arenita-id?roles=Moderator,Member
  body: none
  auth: bearer
}

params:query {
  roles: Moderator,Member
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  { "Moderator", "Member" }
}

settings {
  encodeUrl: true
  timeout: 0
}
